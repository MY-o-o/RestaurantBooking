msgstr "Повторіть пароль"

msgid "Create a new password"
msgstr "Створіть новий пароль"

msgid "Repeat the new password"
msgstr "Повторіть новий пароль"

msgid "Account created successfully."
msgstr "Акаунт успішно створено."

msgid "Please wait before requesting another reset link."
msgstr "Зачекайте перед запитом ще одного посилання для скидання."

